{
  "name": "pauseai-uk",
  "private": true,
  "scripts": {
    "dev": "npx live-server site",
    "lighthouse": "npx lighthouse https://pauseai.uk --output=html --output=json --output-path=lighthouse-report --view",
    "lighthouse:dev": "npx start-server-and-test 'npx serve site -p 3001' http://localhost:3001 'npx lighthouse http://localhost:3001 --output=html --output=json --output-path=lighthouse-report --view'",
    "fonts:update": "cp node_modules/@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2 node_modules/@fontsource-variable/fraunces/files/fraunces-latin-ext-wght-normal.woff2 node_modules/@fontsource-variable/inter/files/inter-latin-wght-normal.woff2 node_modules/@fontsource-variable/inter/files/inter-latin-ext-wght-normal.woff2 site/fonts/"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8"
  }
}
